<Window x:Class="natopdrachtweek8.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:natopdrachtweek8"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="500
        ">
    <Grid>
        <Border Background="White"
                CornerRadius="20"
                Padding="30"
                Width="450"
                VerticalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="het rekenspel"
                               FontSize=" 40"
                               FontWeight="Bold"
                               Foreground="#ff6F08"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,20"/>
                <TextBlock x:Name="sum"
                           FontSize="24"
                           Height="50"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center" Width="317"
                           Background="AliceBlue"/>
                <Button x:Name="newMathButton"
                        Content="nieuwe som"
                        FontSize="10"
                        Height="45"
                        Background="Red"
                        Foreground="White"
                        Margin=" 0,0,0,10"
                        Click="newMathButton_Click"/>
            </StackPanel>


        </Border>
    </Grid>
</Window>
